# The Bridge Hub — environment template (committed, no secrets)
# For daily work, edit .env.bridgehub instead. Copy these names to Vercel.

# ─── Phase 0–1 ─────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_URL=http://localhost:3000
# Project URL only — e.g. https://xxxx.supabase.co (not /rest/v1)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
# Optional — for npm run db:migrate
# DATABASE_URL=postgresql://postgres.[ref]:[password]@...pooler.supabase.com:5432/postgres
# SUPABASE_DB_PASSWORD=
# SUPABASE_DB_REGION=eu-central-1

# Optional — for npm run sync:production (Vercel + Supabase Auth URLs)
# VERCEL_TOKEN=
# VERCEL_PROJECT_ID=
# SUPABASE_ACCESS_TOKEN=

# OPENROUTER_API_KEY=
# CAL_WEBHOOK_SECRET=
# KIT_API_KEY=

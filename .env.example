# The Bridge Hub — environment template (committed, no secrets)
# Two deploys from this repo: marketing (:3000) + screening (:3001).
# For daily work, edit .env.bridgehub. Copy these names to both Vercel projects.

# ─── URLs (both deploys) ───────────────────────────────────────────────────

NEXT_PUBLIC_MARKETING_URL=http://localhost:3000
NEXT_PUBLIC_SCREENING_URL=http://localhost:3001
# Screening-only: magic links, auth callbacks, transactional email links
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ─── Phase 0–1 (screening deploy) ──────────────────────────────────────────

# Project URL only — e.g. https://xxxx.supabase.co (not /rest/v1)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
# Optional — for npm run db:migrate
# DATABASE_URL=postgresql://postgres.[ref]:[password]@...pooler.supabase.com:5432/postgres
# SUPABASE_DB_PASSWORD=
# SUPABASE_DB_REGION=eu-central-1

# Optional — for npm run sync:production (Vercel + Supabase Auth URLs)
# VERCEL_TOKEN=
# VERCEL_PROJECT_ID=
# VERCEL_SCREENING_PROJECT_ID=
# VERCEL_MARKETING_PROJECT_ID=
# SUPABASE_ACCESS_TOKEN=

# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.5-pro
# NEXT_PUBLIC_CAL_EMBED_URL=https://cal.com/your-username/clarity-call
# CAL_WEBHOOK_SECRET=

# ─── Marketing deploy only (/free-class) ───────────────────────────────────

# Mux → Settings → Access Tokens
# MUX_TOKEN_ID=
# MUX_TOKEN_SECRET=
# Mux → video asset → Playback IDs (public) — required for watch-page player
# NEXT_PUBLIC_MUX_PLAYBACK_ID=

# Kit — free class signup
# KIT_API_KEY=
# Kit — free class list (also used by landing "Still not sure?" newsletter)
# KIT_FREE_CLASS_FORM_ID=
# Kit tag for landing "Still not sure?" signups — create tag "still-not-sure" in Kit
# KIT_STILL_NOT_SURE_TAG_ID=

# ─── Marketing deploy only (/work-with-me/speaking/enquire) ───────────────

# Kit — speaking enquiry form (same account/API key as free class, separate form)
# KIT_SPEAKING_ENQUIRY_FORM_ID=

# Resend — instant speaking enquiry notification to Caroline (separate API key
# from screening's magic-link Resend usage; scope to the marketing project)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=The Bridge Hub <onboarding@resend.dev>
# SPEAKING_ENQUIRY_NOTIFY_EMAIL=

# ─── Marketing deploy only (parked /discovery-call — optional) ───────────

# Cal.com — 15 min Discovery Call event (distinct from screening's
# NEXT_PUBLIC_CAL_EMBED_URL, which is the 45 min Clarity Call)
# NEXT_PUBLIC_CAL_DISCOVERY_EMBED_URL=https://cal.com/your-username/discovery-call

# The Bridge Hub — environment template (committed, no secrets)
# Two deploys from this repo: marketing (:3000) + screening (:3001).
# For daily work, edit .env.bridgehub. Copy these names to both Vercel projects.

# ─── URLs (both deploys) ───────────────────────────────────────────────────

NEXT_PUBLIC_MARKETING_URL=http://localhost:3000
NEXT_PUBLIC_SCREENING_URL=http://localhost:3001
# Screening-only: magic links, auth callbacks, transactional email links
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ─── Phase 0–1 (screening deploy) ──────────────────────────────────────────

# Project URL only — e.g. https://xxxx.supabase.co (not /rest/v1)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
# Optional — for npm run db:migrate
# DATABASE_URL=postgresql://postgres.[ref]:[password]@...pooler.supabase.com:5432/postgres
# SUPABASE_DB_PASSWORD=
# SUPABASE_DB_REGION=eu-central-1

# Optional — for npm run sync:production (Vercel + Supabase Auth URLs)
# VERCEL_TOKEN=
# VERCEL_PROJECT_ID=
# VERCEL_SCREENING_PROJECT_ID=
# VERCEL_MARKETING_PROJECT_ID=
# SUPABASE_ACCESS_TOKEN=

# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.5-pro
# NEXT_PUBLIC_CAL_EMBED_URL=https://cal.com/your-username/clarity-call
# CAL_WEBHOOK_SECRET=

# ─── Marketing deploy only (/free-class) ───────────────────────────────────

# Mux → Settings → Access Tokens
# MUX_TOKEN_ID=
# MUX_TOKEN_SECRET=
# Mux → video asset → Playback IDs (public) — required for watch-page player
# NEXT_PUBLIC_MUX_PLAYBACK_ID=

# Kit — free class signup
# KIT_API_KEY=
# KIT_FREE_CLASS_FORM_ID=
